{
  "name": "basketweaver",
  "version": "1.4.0",
  "description": "EverQuest fistweaving timing overlay",
  "author": "Basketweaver",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "manual": "md-to-pdf MANUAL.md"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "electron": "^31.0.0",
    "electron-builder": "^24.0.0",
    "electron-vite": "^2.3.0",
    "md-to-pdf": "^5.2.5",
    "typescript": "^5.4.0",
    "vite": "^5.0.0"
  },
  "dependencies": {
    "electron-updater": "^6.0.0"
  },
  "build": {
    "appId": "com.basketweaver.app",
    "productName": "Basketweaver",
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "resources/icon.ico",
      "forceCodeSigning": false,
      "artifactName": "Basketweaver-Setup-${version}.exe"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "publish": {
      "provider": "github",
      "owner": "Greggles42",
      "repo": "BasketWeaver"
    }
  }
}
